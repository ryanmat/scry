      <scripts>
        <groovyScript><![CDATA[
// Description: Collects drift metrics from Scry API /drift endpoint.
// Description: Stores PSI and ADWIN drift detection results as DataSource metrics.

import groovy.json.JsonSlurper

// Configuration
def apiUrl = hostProps.get("scry.api.url") ?: "https://your-scry-api.example.com"
def timeout = 10000 // 10 seconds

try {
    def startTime = System.currentTimeMillis()

    // Make HTTP request to drift endpoint
    def conn = new URL("${apiUrl}/drift").openConnection()
    conn.setConnectTimeout(timeout)
    conn.setReadTimeout(timeout)
    def status = conn.getResponseCode()
    def responseTime = System.currentTimeMillis() - startTime

    if (status == 200) {
        def json = new JsonSlurper().parseText(conn.getInputStream().getText("UTF-8"))

        def featureDrift = json.feature_drift ?: [:]
        def predictionDrift = json.prediction_drift ?: [:]

        // Feature drift metrics
        def hasFeatureDrift = featureDrift.has_drift ? 1 : 0
        def maxPsi = featureDrift.max_psi ?: 0.0
        def psiThreshold = featureDrift.threshold ?: 0.2

        // Prediction drift metrics
        def hasPredictionDrift = predictionDrift.has_drift ? 1 : 0
        def driftScore = predictionDrift.score ?: 0.0
        def driftThreshold = predictionDrift.threshold ?: 0.0
        def meanErrorBefore = predictionDrift.mean_before ?: 0.0
        def meanErrorAfter = predictionDrift.mean_after ?: 0.0

        // Output metrics
        println "HasFeatureDrift=${hasFeatureDrift}"
        println "MaxPsiValue=${maxPsi}"
        println "PsiThreshold=${psiThreshold}"
        println "HasPredictionDrift=${hasPredictionDrift}"
        println "DriftScore=${driftScore}"
        println "DriftThreshold=${driftThreshold}"
        println "MeanErrorBefore=${meanErrorBefore}"
        println "MeanErrorAfter=${meanErrorAfter}"
        println "ApiStatus=1"
        println "ApiLatencyMs=${responseTime}"

    } else {
        // API returned error
        println "HasFeatureDrift=0"
        println "MaxPsiValue=0"
        println "PsiThreshold=0.2"
        println "HasPredictionDrift=0"
        println "DriftScore=0"
        println "DriftThreshold=0"
        println "MeanErrorBefore=0"
        println "MeanErrorAfter=0"
        println "ApiStatus=0"
        println "ApiLatencyMs=${responseTime}"
    }

} catch (Exception e) {
    // Connection or parsing error
    println "HasFeatureDrift=0"
    println "MaxPsiValue=0"
    println "PsiThreshold=0.2"
    println "HasPredictionDrift=0"
    println "DriftScore=0"
    println "DriftThreshold=0"
    println "MeanErrorBefore=0"
    println "MeanErrorAfter=0"
    println "ApiStatus=0"
    println "ApiLatencyMs=0"
}

return 0
]]></groovyScript>
