      <scripts>
        <groovyScript><![CDATA[
// Description: Collects forecast accuracy metrics from Scry API.
// Description: Stores per-horizon and stability metrics on the resource.

import groovy.json.JsonSlurper

// Configuration
def apiUrl = hostProps.get("scry.api.url") ?: "https://your-scry-api.example.com"
def timeout = 10000 // 10 seconds

try {
    def startTime = System.currentTimeMillis()

    // Make HTTP request to accuracy endpoint
    def conn = new URL("${apiUrl}/accuracy").openConnection()
    conn.setConnectTimeout(timeout)
    conn.setReadTimeout(timeout)
    def status = conn.getResponseCode()
    def responseTime = System.currentTimeMillis() - startTime

    if (status == 200) {
        def json = new JsonSlurper().parseText(conn.getInputStream().getText("UTF-8"))

        // Per-horizon metrics
        ["15m", "1h", "4h", "24h"].each { horizon ->
            ["Picp", "Mae", "Mase", "Mpiw"].each { metric ->
                def key = "${metric}${horizon}"
                def value = json[key] ?: 0
                println "${key}=${value}"
            }
        }

        // Stability metrics
        println "TransitionRate=${json.TransitionRate ?: 0}"
        println "ConfidenceStd=${json.ConfidenceStd ?: 0}"
        println "DominantClusterPct=${json.DominantClusterPct ?: 0}"

        // Observation count
        println "ObservationCount=${json.ObservationCount ?: 0}"

        // Operational metrics
        println "ApiLatencyMs=${responseTime}"
        println "ApiStatus=1"

    } else {
        // API returned error - output zeros for all metrics
        ["15m", "1h", "4h", "24h"].each { horizon ->
            ["Picp", "Mae", "Mase", "Mpiw"].each { metric ->
                println "${metric}${horizon}=0"
            }
        }
        println "TransitionRate=0"
        println "ConfidenceStd=0"
        println "DominantClusterPct=0"
        println "ObservationCount=0"
        println "ApiLatencyMs=${responseTime}"
        println "ApiStatus=0"
    }

} catch (Exception e) {
    // Connection or parsing error - output zeros
    ["15m", "1h", "4h", "24h"].each { horizon ->
        ["Picp", "Mae", "Mase", "Mpiw"].each { metric ->
            println "${metric}${horizon}=0"
        }
    }
    println "TransitionRate=0"
    println "ConfidenceStd=0"
    println "DominantClusterPct=0"
    println "ObservationCount=0"
    println "ApiLatencyMs=0"
    println "ApiStatus=0"
}

return 0
]]></groovyScript>
