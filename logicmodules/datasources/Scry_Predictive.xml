      <scripts>
        <groovyScript><![CDATA[
// Description: Collects predictions from Scry Predictive API.
// Description: Stores prediction state as metrics on the resource.

import com.santaba.agent.groovyapi.http.*
import groovy.json.JsonSlurper

// Configuration
def apiUrl = hostProps.get("scry.api.url") ?: "https://your-scry-api.example.com"
def resourceId = hostProps.get("system.displayName")
def timeout = 10000 // 10 seconds

// Priority mapping
def priorityMap = [
    "LOW": 1,
    "MEDIUM": 2,
    "HIGH": 3
]

// Action mapping (which clusters need action)
def actionClusters = ["PRE_SCALE", "PRE_FAILURE", "ACTIVE_DEGRADATION", "ANOMALY"]

try {
    def startTime = System.currentTimeMillis()

    // Build request URL
    def encodedResourceId = URLEncoder.encode(resourceId, "UTF-8")

    // Make HTTP request
    def httpClient = HTTP.open(apiUrl, timeout)
    def response = httpClient.get("/predict/lookup?resource_id=${encodedResourceId}")
    def responseTime = System.currentTimeMillis() - startTime

    if (response.getStatusCode() == 200) {
        def json = new JsonSlurper().parseText(response.getBody())

        // Extract values
        def clusterId = json.cluster_id ?: 0
        def clusterName = json.cluster_name ?: "NORMAL"
        def confidence = (json.confidence ?: 0.0) * 100  // Convert to percentage
        def priority = priorityMap[json.priority] ?: 1
        def isNormal = (clusterName == "NORMAL") ? 1 : 0
        def needsAction = actionClusters.contains(clusterName) ? 1 : 0

        // Output metrics
        println "ClusterId=${clusterId}"
        println "Confidence=${confidence}"
        println "Priority=${priority}"
        println "IsNormal=${isNormal}"
        println "NeedsAction=${needsAction}"
        println "ApiLatencyMs=${responseTime}"
        println "ApiStatus=1"

    } else {
        // API returned error
        println "ClusterId=0"
        println "Confidence=0"
        println "Priority=1"
        println "IsNormal=1"
        println "NeedsAction=0"
        println "ApiLatencyMs=${responseTime}"
        println "ApiStatus=0"
    }

} catch (Exception e) {
    // Connection or parsing error
    println "ClusterId=0"
    println "Confidence=0"
    println "Priority=1"
    println "IsNormal=1"
    println "NeedsAction=0"
    println "ApiLatencyMs=0"
    println "ApiStatus=0"
}

return 0
]]></groovyScript>
