      <scripts>
        <groovyScript><![CDATA[
// Description: Collects the Scry X-DEC reconstruction-anomaly score for this resource.
// Description: Polls /anomaly/reconstruction/lookup and emits the error/threshold ratio and flag.

import com.santaba.agent.groovyapi.http.*
import groovy.json.JsonSlurper

// Configuration
def apiUrl = hostProps.get("scry.api.url") ?: "https://your-scry-api.example.com"
def resourceId = hostProps.get("system.displayName")
def timeout = 10000 // 10 seconds

try {
    def startTime = System.currentTimeMillis()

    // Score this resource's most recent window via the reconstruction endpoint.
    def encodedResourceId = URLEncoder.encode(resourceId, "UTF-8")
    def httpClient = HTTP.open(apiUrl, timeout)
    def response = httpClient.get("/anomaly/reconstruction/lookup?resource_id=${encodedResourceId}")
    def responseTime = System.currentTimeMillis() - startTime

    if (response.getStatusCode() == 200) {
        def json = new JsonSlurper().parseText(response.getBody())

        def isAnomaly = json.is_anomaly ? 1 : 0
        // ratio is null until a healthy threshold is baked, or when the window was too
        // short / had no numerical data to score; treat null as 0 (no alert).
        def anomalyScore = json.ratio != null ? json.ratio : 0.0
        def severity = json.severity ?: 1
        // coverage is the fraction of the model's numerical features actually scored;
        // a low value flags a data-collection gap even when AnomalyScore reads 0.
        def coverage = json.coverage != null ? json.coverage : 0.0

        // Output metrics
        println "IsAnomaly=${isAnomaly}"
        println "AnomalyScore=${anomalyScore}"
        println "ViolatedMetricCount=0"
        println "Severity=${severity}"
        println "Coverage=${coverage}"
        println "ApiStatus=1"
        println "ApiLatencyMs=${responseTime}"

    } else {
        // Non-200: 404 (no recent data for this resource) and 409 (ambiguous name) are
        // per-resource conditions on a healthy API. A 503 (model not loaded or no data
        // source) or any other 5xx means the service cannot serve, so it is reported
        // unhealthy; a genuine connection failure is caught below.
        def status = response.getStatusCode()
        def apiStatus = (status == 404 || status == 409) ? 1 : 0
        println "IsAnomaly=0"
        println "AnomalyScore=0"
        println "ViolatedMetricCount=0"
        println "Severity=1"
        println "Coverage=0"
        println "ApiStatus=${apiStatus}"
        println "ApiLatencyMs=${responseTime}"
    }

} catch (Exception e) {
    // Connection or parsing error: the API is genuinely unreachable.
    println "IsAnomaly=0"
    println "AnomalyScore=0"
    println "ViolatedMetricCount=0"
    println "Severity=1"
    println "Coverage=0"
    println "ApiStatus=0"
    println "ApiLatencyMs=0"
}

return 0
]]></groovyScript>
