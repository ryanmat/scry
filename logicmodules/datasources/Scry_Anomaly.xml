      <scripts>
        <groovyScript><![CDATA[
// Description: Collects anomaly detection metrics from Scry API /anomaly endpoint.
// Description: Stores forecast-based anomaly detection results as DataSource metrics.

import com.santaba.agent.groovyapi.http.*
import groovy.json.JsonSlurper

// Configuration
def apiUrl = hostProps.get("scry.api.url") ?: "https://your-scry-api.example.com"
def timeout = 10000 // 10 seconds

// Severity string to numeric mapping
def severityMap = [
    "low": 1,
    "medium": 2,
    "high": 3,
    "critical": 4
]

try {
    def startTime = System.currentTimeMillis()

    // Make HTTP request to anomaly endpoint
    def httpClient = HTTP.open(apiUrl, timeout)
    def response = httpClient.get("/anomaly")
    def responseTime = System.currentTimeMillis() - startTime

    if (response.getStatusCode() == 200) {
        def json = new JsonSlurper().parseText(response.getBody())

        def isAnomaly = json.is_anomaly ? 1 : 0
        def anomalyScore = json.anomaly_score ?: 0.0
        def violatedMetrics = json.violated_metrics ?: []
        def severity = severityMap[json.severity] ?: 1

        // Output metrics
        println "IsAnomaly=${isAnomaly}"
        println "AnomalyScore=${anomalyScore}"
        println "ViolatedMetricCount=${violatedMetrics.size()}"
        println "Severity=${severity}"
        println "ApiStatus=1"
        println "ApiLatencyMs=${responseTime}"

    } else {
        // API returned error
        println "IsAnomaly=0"
        println "AnomalyScore=0"
        println "ViolatedMetricCount=0"
        println "Severity=1"
        println "ApiStatus=0"
        println "ApiLatencyMs=${responseTime}"
    }

} catch (Exception e) {
    // Connection or parsing error
    println "IsAnomaly=0"
    println "AnomalyScore=0"
    println "ViolatedMetricCount=0"
    println "Severity=1"
    println "ApiStatus=0"
    println "ApiLatencyMs=0"
}

return 0
]]></groovyScript>
