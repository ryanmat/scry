{
  "name": "Scry Model Health",
  "description": "Monitors ML model operational health including feature drift, prediction drift, forecast anomalies, and API performance across all Scry-monitored resources.",
  "groupFullPath": "Scry",
  "sharable": true,
  "widgetTokens": [],
  "widgetsConfig": {
    "widgetsConfigVersion": 2,
    "widgets": [
      {
        "position": {
          "col": 1,
          "row": 1,
          "sizex": 3,
          "sizey": 2
        },
        "config": {
          "bigNumberInfo": {
            "dataPoints": [
              {
                "dataSourceFullName": "Scry_Drift",
                "dataPointName": "HasFeatureDrift",
                "aggregateFunction": "MAX",
                "instanceName": "*",
                "deviceGroupFullPath": "*",
                "deviceDisplayName": "*"
              }
            ],
            "counters": [],
            "virtualDataPoints": [],
            "colorThresholds": [
              {
                "level": 2,
                "op": "=",
                "value": 1,
                "colorMode": "threshold"
              }
            ],
            "rightLabel": "Feature Drift",
            "bottomLabel": "0 = No Drift, 1 = Drift Detected"
          },
          "displaySettings": {
            "showAlertStatusBar": true
          },
          "type": "bigNumber",
          "timescale": "1hour",
          "version": 2,
          "name": "Feature Drift Status",
          "description": "Shows 1 if any resource has feature distribution drift (PSI above threshold)"
        }
      },
      {
        "position": {
          "col": 4,
          "row": 1,
          "sizex": 3,
          "sizey": 2
        },
